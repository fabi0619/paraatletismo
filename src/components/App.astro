---
import "../styles/index.css";
import { AthleteModal } from "../features/auth/components/AthleteModal";
import { AthletesView } from "../features/athletes/components/AthletesView";
---

<!-- Elemento decorativo de fondo -->
<div class="bg-glow"></div>

<!-- Pantalla de Login antigua eliminada (migrada a /login) -->

<!-- Sección de Encabezado -->
<header class="app-header">
  <div class="header-container">
    <div class="logo-area">
      <div class="logo-badge">
        <div class="logo-badge-icon">
          <span class="material-icons-round">sports_athletics</span>
        </div>
        <div class="logo-badge-text">
          <h1>VALLE <span class="highlight">PARAATLETISMO</span></h1>
          <p>Portal de Gestión Deportiva</p>
        </div>
      </div>
    </div>

    <!-- Panel de Estadísticas en el Encabezado -->
    <div class="stats-panel">
      <div class="stat-card" id="stat-athletes">
        <span class="material-icons-round text-red">groups</span>
        <div>
          <h3 class="stat-value">0</h3>
          <p class="stat-label">Atletas</p>
        </div>
      </div>
      <div class="stat-card" id="stat-championships">
        <span class="material-icons-round text-red">emoji_events</span>
        <div>
          <h3 class="stat-value">0</h3>
          <p class="stat-label">Eventos creados</p>
        </div>
      </div>
    </div>

    <!-- Acciones del Header -->
    <div
      class="header-actions"
      style="display: flex; align-items: center; gap: 12px;"
    >
      <!-- Botón de Ingreso Elegante (Visible por defecto cuando no hay sesión) -->
      <a
        href="/login"
        class="btn btn-secondary"
        id="btn-portal-login"
        style="border: 1.5px solid var(--primary-red); color: var(--primary-red); font-weight: 700; border-radius: var(--radius-md); display: inline-flex; align-items: center; gap: 8px;"
      >
        <span class="material-icons-round">login</span>
        Ingresar al Portal
      </a>

      <!-- Indicador de Sesión Activa -->
      <div
        class="indicador-sesion"
        id="indicador-sesion"
        style="display: none;"
      >
        <div class="usuario-info">
          <span class="material-icons-round text-red" style="font-size: 32px;"
            >account_circle</span
          >
          <div
            class="usuario-textos"
            style="display: flex; flex-direction: column;"
          >
            <h4
              id="sesion-nombre-usuario"
              style="font-size: 0.85rem; font-weight: 700; line-height: 1.1; color: var(--bg-dark);"
            >
              Nombre Usuario
            </h4>
            <span
              class="badge"
              id="sesion-badge-rol"
              style="font-size: 0.65rem; padding: 1px 6px; width: fit-content; margin-top: 3px; background-color: var(--primary-red-light); color: var(--primary-red); font-weight: bold; border-radius: 4px;"
              >ADMIN</span
            >
          </div>
        </div>
        <button
          class="btn btn-primary btn-sm"
          id="btn-mi-perfil"
          title="Mi Perfil"
          style="padding: 6px 10px; border-radius: 8px; display: none; margin-right: 5px; font-weight: 700; gap: 4px;"
        >
          <span class="material-icons-round" style="font-size: 18px;"
            >account_box</span
          >
          Perfil
        </button>
        <button
          class="btn btn-secondary btn-sm"
          id="btn-cerrar-sesion"
          title="Cerrar Sesión"
          style="padding: 6px; border-radius: 8px;"
        >
          <span class="material-icons-round" style="font-size: 18px;"
            >logout</span
          >
        </button>
      </div>

      <button
        class="btn btn-primary"
        id="btn-open-register"
        style="display: none;"
      >
        <span class="material-icons-round">person_add</span>
        Registrar Atleta
      </button>
    </div>
  </div>
</header>

<!-- Diseño del Contenido Principal -->
<main class="app-content">
  <!-- Navegación por pestañas -->
  <nav
    class="navegacion-principal"
    id="navegacion-principal"
    style="display: none; margin-bottom: 25px; display: flex; gap: 15px; border-bottom: 2px solid var(--border-color); padding-bottom: 10px;"
  >
    <button
      type="button"
      class="btn btn-secondary tab-enlace activo"
      id="enlace-tab-atletas"
      style="border-radius: var(--radius-sm); font-size: 0.9rem; padding: 8px 16px;"
    >
      <span class="material-icons-round">groups</span>
      Atletas del Valle
    </button>
    <button
      type="button"
      class="btn btn-secondary tab-enlace"
      id="enlace-tab-logros"
      style="border-radius: var(--radius-sm); font-size: 0.9rem; padding: 8px 16px;"
    >
      <span class="material-icons-round">emoji_events</span>
      Logros de Entrenadores
    </button>
    <button
      type="button"
      class="btn btn-secondary tab-enlace"
      id="enlace-tab-eventos"
      style="border-radius: var(--radius-sm); font-size: 0.9rem; padding: 8px 16px;"
    >
      <span class="material-icons-round">event_available</span>
      Eventos
    </button>
  </nav>

  <!-- VISTA PRINCIPAL DE ATLETAS (React + Tanstack Query) -->
  <div id="contenedor-vista-atletas">
    <AthletesView client:load />
  </div>

  <!-- VISTA SECUNDARIA DE LOGROS DE PROFESORES -->
  <div id="contenedor-vista-logros" style="display: none;">
    <section class="filter-section">
      <div
        class="section-title-between"
        style="margin-bottom: 0; display: flex; justify-content: space-between; align-items: center; width: 100%;"
      >
        <div class="logo-text">
          <h2 class="section-title" style="font-size: 1.25rem;">
            Palmarés e Historial de Profesores
          </h2>
          <p
            style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;"
          >
            Logros significativos obtenidos por entrenadores con atletas del
            Valle
          </p>
        </div>
        <button type="button" class="btn btn-primary" id="btn-registrar-logro">
          <span class="material-icons-round">workspace_premium</span>
          Registrar Logro
        </button>
      </div>
    </section>

    <section class="athletes-section" style="margin-top: 25px;">
      <!-- Lista de Logros de Profesores -->
      <div
        class="athletes-grid"
        id="logros-grid"
        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;"
      >
        <!-- Inyectado dinámicamente por JS -->
      </div>

      <div class="empty-state" id="logros-vacio-state" style="display: none;">
        <span class="material-icons-round empty-icon">emoji_events</span>
        <h3>Sin logros registrados</h3>
        <p>
          Los entrenadores del Valle aún no han registrado logros con
          deportistas en esta sesión.
        </p>
      </div>
    </section>
  </div>

  <!-- VISTA SECUNDARIA DE EVENTOS -->
  <div id="contenedor-vista-eventos" style="display: none;">
    <section class="filter-section">
      <div
        class="section-title-between"
        style="margin-bottom: 0; display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 16px; flex-wrap: wrap;"
      >
        <div class="logo-text">
          <h2 class="section-title" style="font-size: 1.25rem;">
            Calendario de Eventos
          </h2>
          <p
            style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;"
          >
            Registro oficial de eventos por ubicación y rango de fechas
          </p>
        </div>
        <button type="button" class="btn btn-primary" id="btn-registrar-evento">
          <span class="material-icons-round">add_location_alt</span>
          Registrar Evento
        </button>
      </div>
    </section>

    <section class="athletes-section eventos-section" style="margin-top: 25px;">
      <div class="eventos-grid" id="eventos-grid">
        <!-- Inyectado dinámicamente por JS -->
      </div>

      <div class="empty-state" id="eventos-vacio-state" style="display: none;">
        <span class="material-icons-round empty-icon">event_busy</span>
        <h3>Sin eventos registrados</h3>
        <p>
          Admin y profesores pueden crear el calendario de eventos desde esta
          sección.
        </p>
        <button class="btn btn-primary" id="btn-empty-evento-trigger">
          <span class="material-icons-round">add_location_alt</span>
          Registrar Evento
        </button>
      </div>
    </section>
  </div>
</main>

<!-- Pie de Página -->
<footer class="app-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <h3>Atletas del Valle del Cauca</h3>
      <p>Impulsando el deporte y el talento regional.</p>
    </div>

    <div class="footer-links">
      <h4>Enlaces</h4>
      <ul>
        <li><a href="#">Inicio</a></li>
        <li><a href="#">Atletas</a></li>
        <li><a href="#">Logros</a></li>
        <li><a href="#">Contacto</a></li>
      </ul>
    </div>

    <div class="footer-social">
      <h4>Síguenos</h4>
      <div class="social-icons">
        <a href="#">Facebook</a>
        <a href="#">Instagram</a>
        <a href="#">X</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>
      &copy; 2026 Atletas del Valle del Cauca. Todos los derechos reservados.
    </p>
  </div>
</footer>

<!-- MODAL: REGISTRO / EDICIÓN DE ATLETA -->
<div class="modal-overlay" id="modal-agregar-evento" style="display: none;">
  <div class="modal-content" style="max-width: 680px;">
    <div class="modal-header">
      <div class="modal-title-group">
        <span class="material-icons-round modal-icon">event_available</span>
        <div>
          <h3>Registrar Evento</h3>
          <p>Nombre, ubicación y calendario del evento.</p>
        </div>
      </div>
      <button class="btn-close-sm" id="btn-cerrar-modal-evento">
        <span class="material-icons-round">close</span>
      </button>
    </div>

    <form id="form-evento" class="compact-form" novalidate>
      <div class="form-group">
        <label for="evento-nombre"
          >Nombre del Evento <span class="required">*</span></label
        >
        <input
          type="text"
          id="evento-nombre"
          required
          placeholder="Ej. Juegos Paranacionales"
        />
        <span class="error-msg" id="error-evento-nombre">Requerido.</span>
      </div>

      <div class="form-group-row" style="gap: 10px;">
        <div class="form-group" style="flex: 1;">
          <label for="evento-country"
            >País <span class="required">*</span></label
          >
          <div class="custom-select-wrapper">
            <select id="evento-country" required>
              <option value="">Cargando países...</option>
            </select>
            <span class="material-icons-round select-arrow">expand_more</span>
          </div>
          <span class="error-msg" id="error-evento-country">Requerido.</span>
        </div>
        <div class="form-group" style="flex: 1;">
          <label for="evento-state"
            >Departamento / Estado <span class="required">*</span></label
          >
          <div class="custom-select-wrapper">
            <select id="evento-state" required disabled>
              <option value="">Elija país...</option>
            </select>
            <span class="material-icons-round select-arrow">expand_more</span>
          </div>
          <span class="error-msg" id="error-evento-state">Requerido.</span>
        </div>
        <div class="form-group" style="flex: 1;">
          <label for="evento-city">Ciudad <span class="required">*</span></label
          >
          <div class="custom-select-wrapper">
            <select id="evento-city" required disabled>
              <option value="">Elija departamento...</option>
            </select>
            <span class="material-icons-round select-arrow">expand_more</span>
          </div>
          <span class="error-msg" id="error-evento-city">Requerido.</span>
        </div>
      </div>

      <div class="form-group-row">
        <div class="form-group">
          <label for="evento-fecha-inicio"
            >Fecha de Inicio <span class="required">*</span></label
          >
          <input type="date" id="evento-fecha-inicio" required />
          <span class="error-msg" id="error-evento-fecha-inicio"
            >Requerido.</span
          >
        </div>
        <div class="form-group">
          <label for="evento-fecha-fin"
            >Fecha de Finalización <span class="required">*</span></label
          >
          <input type="date" id="evento-fecha-fin" required />
          <span class="error-msg" id="error-evento-fecha-fin">Requerido.</span>
        </div>
      </div>

      <div class="evento-date-preview" id="evento-date-preview">
        Seleccione inicio y finalización para ver cómo quedará la fecha.
      </div>

      <div class="form-actions-right">
        <button
          type="button"
          class="btn btn-secondary"
          id="btn-cancelar-evento"
        >
          Cancelar
        </button>
        <button type="button" class="btn btn-primary" id="btn-guardar-evento">
          <span class="material-icons-round">save</span>
          Guardar Evento
        </button>
      </div>
    </form>
  </div>
</div>

<AthleteModal client:load />

<!-- MODAL: AGREGAR LOGRO DE PROFESOR EN ESPAÑOL -->
<div class="modal-overlay" id="modal-agregar-logro">
  <div class="modal-card">
    <div class="modal-header">
      <div class="modal-title-group">
        <span class="material-icons-round modal-icon">emoji_events</span>
        <h2 style="font-size: 1.2rem; font-weight: 800; color: var(--bg-dark);">
          Registrar Nuevo Logro Deportivo
        </h2>
      </div>
      <button class="btn-close-modal" id="btn-cerrar-modal-logro">
        <span class="material-icons-round">close</span>
      </button>
    </div>

    <div class="modal-body">
      <form id="formulario-logro" novalidate>
        <div class="form-group">
          <label for="logro-atleta"
            >Deportista Asociado <span class="required">*</span></label
          >
          <div class="custom-select-wrapper">
            <select id="logro-atleta" required>
              <option value="">Seleccione el atleta...</option>
            </select>
            <span class="material-icons-round select-arrow">expand_more</span>
          </div>
          <span class="error-msg" id="error-logro-atleta"
            >El atleta es requerido.</span
          >
        </div>

        <div class="form-group-row">
          <div class="form-group flex-2">
            <label for="logro-campeonato"
              >Campeonato / Evento <span class="required">*</span></label
            >
            <input
              type="text"
              id="logro-campeonato"
              required
              placeholder="Ej. Juegos Parapanamericanos Santiago"
            />
            <span class="error-msg" id="error-logro-campeonato"
              >El campeonato es requerido.</span
            >
          </div>
          <div class="form-group flex-1">
            <label for="logro-ano">Año <span class="required">*</span></label>
            <input type="text" id="logro-ano" required placeholder="2023" />
            <span class="error-msg" id="error-logro-ano"
              >El año es requerido.</span
            >
          </div>
        </div>

        <div class="form-group">
          <label for="logro-descripcion"
            >Descripción del Logro Obtenido <span class="required">*</span
            ></label
          >
          <textarea
            id="logro-descripcion"
            required
            placeholder="Ej. Medalla de Oro en Lanzamiento de Bala, imponiendo una nueva marca panamericana de 11.65m"
            style="width: 100%; height: 100px; padding: 10px; border-radius: var(--radius-sm); border: 1.5px solid var(--border-color); font-family: var(--font-family); resize: none; outline: none; transition: var(--transition-smooth);"
          ></textarea>
          <span class="error-msg" id="error-logro-descripcion"
            >La descripción es requerida.</span
          >
        </div>
      </form>
    </div>

    <div class="modal-footer">
      <button type="button" class="btn btn-secondary" id="btn-cancelar-logro"
        >Cancelar</button
      >
      <button type="button" class="btn btn-primary" id="btn-guardar-logro">
        <span class="material-icons-round">check</span>
        Guardar Logro
      </button>
    </div>
  </div>
</div>

<!-- MODAL: EXPEDIENTE COMPLETO / HISTORIAL DE CAMPEONATOS -->
<div class="modal-overlay" id="modal-detail">
  <div class="modal-card modal-large full-screen-profile">
    <div class="modal-header mockup-header-bar">
      <div class="modal-title-group">
        <button class="btn-back-redesign" id="btn-close-detail-modal">
          <span class="material-icons-round">arrow_back</span>
          <span>Regresar</span>
        </button>
      </div>
      <div class="header-action-buttons">
        <button class="btn btn-secondary btn-sm" id="btn-edit-athlete-profile">
          <span class="material-icons-round">edit</span> Editar Perfil
        </button>
      </div>
    </div>

    <div class="modal-body no-padding scroll-y bg-mockup-light">
      <div class="profile-redesign-container">
        <!-- Left Panel: Athlete Details -->
        <div class="profile-redesign-left-panel">
          <h2 class="profile-name">
            <span id="detail-first-name">-</span>
            <span id="detail-last-name" class="highlight-red">-</span>
          </h2>

          <div class="profile-info-list">
            <div class="info-row">
              <span class="info-label">Pruebas:</span>
              <span id="detail-pruebas-dinamicas" class="info-value">-</span>
            </div>
            <div class="info-row">
              <span class="info-label">Clasificación:</span>
              <span id="detail-badge-class" class="info-value">-</span>
            </div>
            <div class="info-row">
              <span class="info-label">Edad:</span>
              <span id="detail-age-full" class="info-value">-</span>
            </div>
            <div class="info-row">
              <span class="info-label">Club:</span>
              <span id="detail-club" class="info-value">-</span>
            </div>
            <!-- Additional Details shown only for Admin/Profesor handled by JS later -->
            <div
              class="info-row private-info"
              id="detail-phone-row"
              style="display:none;"
            >
              <span class="info-label">Teléfono:</span>
              <span id="detail-phone" class="info-value">-</span>
            </div>
            <div
              class="info-row private-info"
              id="detail-email-row"
              style="display:none;"
            >
              <span class="info-label">Correo:</span>
              <span id="detail-email" class="info-value">-</span>
            </div>
          </div>
        </div>

        <!-- Center Section: Avatar, Medals, Timeline -->
        <div class="profile-redesign-center-panel">
          <div class="profile-avatar-wrapper">
            <img
              src=""
              alt="Foto Atleta"
              id="detail-avatar"
              class="profile-avatar-circle"
            />
          </div>

          <!-- Timeline Chart Section -->
          <div class="profile-chart-section">
            <h3 class="section-title-sm">
              Mejores Marcas por Año (2023 - Presente)
            </h3>
            <div id="detail-chart-wrapper" class="chart-container-svg">
              <!-- JS Injected SVG -->
            </div>
          </div>

          <div class="championships-section">
            <div class="section-header-flex">
              <h3 class="section-title-sm">Campeonatos</h3>
              <button
                id="btn-open-championship-form"
                style="display: none; align-items: center; gap: 5px; padding: 6px 14px; font-size: 0.78rem; font-weight: 600; border-radius: 8px; border: 1px solid rgba(220, 38, 38, 0.35); background-color: rgba(220, 38, 38, 0.08); color: #c0392b; cursor: pointer; transition: all 0.25s ease; letter-spacing: 0.3px;"
              >
                <span class="material-icons-round" style="font-size: 15px;"
                  >emoji_events</span
                > Registrar Campeonato
              </button>
            </div>

            <div class="table-responsive">
              <table class="championships-table" id="championships-table-el">
                <thead>
                  <tr>
                    <th>Año</th>
                    <th>Evento</th>
                    <th>Prueba</th>
                    <th>Tiempo/Marca</th>
                    <th>Posición</th>
                    <th>Lugar</th>
                    <th>Fecha</th>
                    <th class="actions-col">Acción</th>
                  </tr>
                </thead>
                <tbody id="detail-championships-table-body">
                  <!-- JS Injected -->
                </tbody>
              </table>
            </div>

            <div
              class="empty-championships-state"
              id="empty-championships-msg"
              style="display: none;"
            >
              <span class="material-icons-round">emoji_events</span>
              <h4>Sin Historial Deportivo</h4>
              <button
                class="btn btn-primary-outline btn-sm mt-3"
                id="btn-empty-champ-trigger"
              >
                Registrar Campeonato
              </button>
            </div>
          </div>
        </div>

        <!-- Right Panel / Bottom: Medals and PDF -->
        <div class="profile-redesign-right-panel">
          <!-- Medals Section -->
          <div class="profile-medals-section">
            <h3 class="section-title-sm">Medallas</h3>
            <div class="medals-flex">
              <div class="medal-item">
                <div class="medal-circle gold"></div>
                <span id="detail-medals-gold">0</span>
              </div>
              <div class="medal-item">
                <div class="medal-circle silver"></div>
                <span id="detail-medals-silver">0</span>
              </div>
              <div class="medal-item">
                <div class="medal-circle bronze"></div>
                <span id="detail-medals-bronze">0</span>
              </div>
            </div>
          </div>

          <div class="docs-section mt-4">
            <div class="section-header-flex">
              <h3 class="section-title-sm">Documentos PDF</h3>
            </div>
            <div class="docs-list" id="detail-docs-list"></div>
            <div class="no-docs-message" id="no-docs-msg">
              <span class="material-icons-round">folder_open</span>
              <p>Sin documentos cargados</p>
            </div>
            <div
              style="margin-top: 15px; display: flex; justify-content: center;"
            >
              <button
                class="btn btn-sm"
                id="btn-trigger-doc-upload"
                style="width: 100%; display: flex; justify-content: center; align-items: center; gap: 6px; background-color: rgba(220, 38, 38, 0.08); color: var(--primary-red); border: 1px dashed rgba(220, 38, 38, 0.3); border-radius: 8px; transition: all 0.3s ease;"
              >
                <span class="material-icons-round" style="font-size: 18px;"
                  >upload_file</span
                > Subir PDF
              </button>
              <input
                type="file"
                id="doc-file-input"
                accept=".pdf"
                style="display: none;"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Hidden Championship Form as Modal -->
      <div
        class="modal-overlay"
        id="championship-form-card"
        style="display: none; z-index: 10000;"
      >
        <div class="modal-content" style="max-width: 600px;">
          <div
            class="card-header-simple"
            style="padding-bottom: 15px; border-bottom: 1px solid #e5e7eb; margin-bottom: 20px;"
          >
            <h4>Nuevo Campeonato / Marca</h4>
            <button class="btn-close-sm" id="btn-close-champ-form">
