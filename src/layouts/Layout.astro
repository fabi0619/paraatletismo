---
interface Props {
	title?: string;
}

const { title = "Valle Oro Puro - Paraatletismo" } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<!-- Etiquetas Meta SEO -->
		<meta
			name="description"
			content="Plataforma de gestión e historial deportivo de atletas de la selección de paraatletismo del Valle del Cauca. Registro, marcas, campeonatos y clasificaciones."
		/>
		<meta
			name="keywords"
			content="paraatletismo, valle del cauca, atletismo adaptado, clasificacion deportiva, indeportes valle"
		/>

		<!-- Fuentes e Iconos -->
		<!-- La fuente Plus Jakarta Sans se carga desde @fontsource-variable (sin CDN externo) -->
		<link
			href="https://fonts.googleapis.com/icon?family=Material+Icons+Round"
			rel="stylesheet"
		/>
	</head>
	<body class="min-h-screen relative">
		<slot />
	</body>
</html>
