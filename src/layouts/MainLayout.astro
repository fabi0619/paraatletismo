---
/**
 * MainLayout.astro
 * ─────────────────────────────────────────────────────────
 * Layout principal reutilizable para TODAS las páginas
 * que necesitan el Header (sesión + stats) y el Footer.
 *
 * Uso:
 *   <MainLayout title="Mi Página">
 *     <!-- contenido aquí -->
 *   </MainLayout>
 *
 * Props:
 *   title  - Título de la pestaña del navegador
 *   class  - Clase CSS adicional para el <main>
 */

interface Props {
  title?: string;
  class?: string;
}

const { title = "Valle Oro Puro - Paraatletismo", class: className } = Astro.props;

import "../styles/global.css";
import "../styles/styles.css";
import { Header } from "../components/layout/Header";
import { AthleteModal } from "../features/auth/components/AthleteModal";
import { CoachModal } from "../features/auth/components/CoachModal";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Plataforma de gestión e historial deportivo de atletas de la selección de paraatletismo del Valle del Cauca."
    />
    <meta
      name="keywords"
      content="paraatletismo, valle del cauca, atletismo adaptado, clasificacion deportiva, indeportes valle"
    />
    <!-- Material Icons -->
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons+Round"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen relative overflow-x-hidden bg-slate-50">
    <!-- Animated background blobs -->
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, hsla(0,75%,45%,0.25) 0%, transparent 70%);"></div>
    <div aria-hidden="true" class="pointer-events-none fixed bottom-0 right-0 h-[30rem] w-[30rem] rounded-full opacity-20 blur-3xl" style="background: hsl(0,75%,45%);"></div>
    <div aria-hidden="true" class="pointer-events-none fixed top-1/2 left-0 h-96 w-96 -translate-y-1/2 -translate-x-1/2 rounded-full opacity-[0.15] blur-3xl" style="background: hsl(348,100%,40%);"></div>

    <!-- Header React con sesión + estadísticas -->
    <Header client:load />

    <!-- Contenido de la página -->
    <main class:list={["relative z-10 w-full max-w-7xl mx-auto rounded-3xl border border-white/40 bg-white/30 p-4 sm:p-6 md:p-10 shadow-xl backdrop-blur-2xl my-8", className]}>
      <slot />
    </main>

    <!-- Modals de Edición/Registro de Cuentas -->
    <AthleteModal client:load />
    <CoachModal client:load />

    <!-- Footer -->
    <footer class="app-footer">

      <div class="footer-container">
        <div class="footer-brand">
          <h3>Atletas del Valle del Cauca</h3>
          <p>Impulsando el deporte y el talento regional.</p>
        </div>
        <div class="footer-links">
          <h4>Navegación</h4>
          <ul class="flex flex-col gap-1">
            <li><a href="/">Inicio</a></li>
            <li><a href="/atletas">Atletas</a></li>
            <li><a href="/profesores">Profesores</a></li>
            <li><a href="/campeonatos">Campeonatos</a></li>
            <li><a href="/logros">Logros</a></li>
            <li><a href="/login">Ingresar</a></li>
          </ul>
        </div>
        <div class="footer-social">
          <h4>Síguenos</h4>
          <div class="social-icons">
            <a href="#">Facebook</a>
            <a href="#">Instagram</a>
            <a href="#">X</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Atletas del Valle del Cauca. Todos los derechos reservados.</p>
      </div>
    </footer>
  </body>
</html>
